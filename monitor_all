#!/usr/bin/env zsh
# QuantForge Paper Trading Monitor
# Pulls LIVE market data from yfinance. Serves dashboard.
# Usage: ./monitor_all  |  Ctrl+C to stop.

set -e
cd "$(dirname "$0")"

echo "========================================================"
echo "  QuantForge Paper Trading  |  LIVE MARKET FEED"
echo "========================================================"
echo ""

source .venv/bin/activate

# Build React dashboard
echo "  Building dashboard..."
(cd paper_trading/dashboard && yarn build) || echo "  Dashboard build skipped (error above)"

# Check if port 5000 is in use by QuantForge — kill only orphaned processes
# Avoids killing non-QuantForge services
fuser 5000/tcp 2>/dev/null && fuser -k 5000/tcp 2>/dev/null || true
sleep 1

python -m paper_trading.ops.monitor
