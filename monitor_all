#!/usr/bin/env zsh
# QuantForge Paper Trading Monitor
# Pulls LIVE market data from yfinance. Serves dashboard.
# Usage: ./monitor_all  |  Ctrl+C to stop.

set -e
cd "$(dirname "$0")"

echo "========================================================"
echo "  QuantForge Paper Trading  |  LIVE MARKET FEED"
echo "========================================================"
echo ""

source .venv/bin/activate

# Kill anything on port 5000 and wait for release
OLD_PID=$(lsof -ti:5000 2>/dev/null)
if [ -n "$OLD_PID" ]; then
    echo "Stopping previous instance (PID $OLD_PID)..."
    kill $OLD_PID 2>/dev/null || true
    # Wait up to 5 seconds for port to release
    for i in $(seq 1 5); do
        if ! lsof -ti:5000 >/dev/null 2>&1; then
            break
        fi
        sleep 1
    done
    # Force kill if still running
    if lsof -ti:5000 >/dev/null 2>&1; then
        kill -9 $OLD_PID 2>/dev/null || true
        sleep 1
    fi
fi

python paper_trading/monitor.py
