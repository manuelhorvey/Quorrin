{
  "name": "eigencapital-dashboard",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build:tokens": "tsx scripts/generate-tokens.ts",
    "generate-palette": "tsx scripts/generate-palette.ts",
    "build:dtcg": "tsx scripts/generate-dtcg.ts",
    "dev": "tsx scripts/generate-tokens.ts && vite --port 3000",
